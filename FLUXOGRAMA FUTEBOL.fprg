<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="FLUXOGRAMA FUTEBOL"/>
        <attribute name="authors" value="DEV"/>
        <attribute name="about" value=""/>
